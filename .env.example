# --- Supabase (required) ---
# Create a free project at https://supabase.com, then copy these from
# Project Settings -> API. See database/README.md for schema setup.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key: server-only, never expose to the client. Used for
# privileged operations (e.g. future Stripe webhook writes).
SUPABASE_SERVICE_ROLE_KEY=

# --- App ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Finnhub (real-time stock quotes + market news) ---
# Required for the Investing and News tabs. Free tier: sign up at
# https://finnhub.io/register, then copy your API key from the dashboard.
# Free tier allows ~60 API calls/minute; lib/finnhub/* caches and batches
# requests to stay well under that. Server-only - never expose to the client.
FINNHUB_API_KEY=

# --- Future: Stripe (subscriptions) ---
# Leave blank until you're ready to wire real billing. lib/stripe/* no-ops
# without these.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PREMIUM_PRICE_ID=

# --- Future: Plaid (bank connections) ---
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# --- Future: OpenAI (AI assistant upgrade) ---
OPENAI_API_KEY=
